{
  "name": "elasticsearch-sink-sessions-detected",
  "config": {
    "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
    "tasks.max": "1",
    "topics": "sessions.detected",
    "external.resource.usage": "INDEX",
    "topic.to.external.resource.mapping": "sessions.detected:sessions-detected",
    "connection.url": "http://elasticsearch:9200",
    "connection.compression": "false",
    "batch.size": "10",
    "linger.ms": "1000",
    "key.ignore": "false",
    "schema.ignore": "false",
    "errors.tolerance": "all",
    "errors.log.enable": "true",
    "elastic.security.protocol": "PLAINTEXT"
  }
}
