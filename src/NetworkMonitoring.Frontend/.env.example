# Empty / unset → same-origin `/devices` (Vite dev proxy → localhost:5090, or nginx proxy → backend in Docker).
# Set only when you intentionally call the backend from another origin (requires backend CORS).
# VITE_BACKEND_BASE_URL=http://localhost:5090

# Override proxy target for `npm run dev` (defaults to http://localhost:5090).
# VITE_DEV_PROXY_TARGET=http://localhost:5090
