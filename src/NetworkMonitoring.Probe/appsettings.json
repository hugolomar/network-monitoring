{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Probe": {
    "TSharkPath": "tshark",
    "InterfaceName": "eth0",
    "CaptureFilter": "",
    "SessionDeduplicationWindowMinutes": 10,
    "DeviceDeduplicationWindowMinutes": 10,
    "EnableConsole": true,
    "EnableKafka": true,
    "KafkaBootstrapServers": "localhost:9092,localhost:9093,localhost:9094",
    "SchemaRegistryUrl": "http://localhost:8081",
    "KafkaSessionTopic": "sessions.detected",
    "KafkaDeviceTopic": "devices.detected",
    "KafkaSecurityProtocol": "Plaintext"
  }
}
